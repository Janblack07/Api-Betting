{
    "openapi": "3.0.0",
    "info": {
        "title": "Casa de Apuestas API",
        "description": "API para casa de apuestas: autenticación, usuarios, deportes, eventos, cuotas, wallet y apuestas.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api/v1",
            "description": "API versión 1"
        }
    ],
    "paths": {
        "/admin/users/{user}/account": {
            "patch": {
                "tags": [
                    "Administración"
                ],
                "description": "HU-05: Bloquear, suspender o reactivar usuario. Motivo obligatorio al bloquear/suspender. Revoca tokens si aplica.",
                "operationId": "adminModerateUserAccount",
                "parameters": [
                    {
                        "name": "user",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "status"
                                ],
                                "properties": {
                                    "status": {
                                        "type": "string",
                                        "enum": [
                                            "blocked",
                                            "suspended",
                                            "active"
                                        ]
                                    },
                                    "reason": {
                                        "type": "string",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Usuario actualizado"
                    },
                    "401": {
                        "description": "No autenticado"
                    },
                    "403": {
                        "description": "Sin permisos"
                    },
                    "422": {
                        "description": "Validación"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/auth/register": {
            "post": {
                "tags": [
                    "Autenticación"
                ],
                "description": "HU-01: Registro con rol customer y wallet USD en saldo 0. Devuelve token Sanctum.",
                "operationId": "authRegister",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "maxLength": 150
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Usuario creado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "data": {
                                            "properties": {
                                                "token": {
                                                    "type": "string"
                                                },
                                                "token_type": {
                                                    "type": "string",
                                                    "example": "Bearer"
                                                },
                                                "user": {
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Errores de validación"
                    }
                }
            }
        },
        "/auth/login": {
            "post": {
                "tags": [
                    "Autenticación"
                ],
                "description": "HU-02: Inicio de sesión. Usuarios bloqueados o suspendidos reciben 403.",
                "operationId": "authLogin",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Credenciales válidas",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "data": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Credenciales incorrectas"
                    },
                    "403": {
                        "description": "Cuenta bloqueada o suspendida"
                    },
                    "422": {
                        "description": "Validación"
                    }
                }
            }
        },
        "/auth/logout": {
            "post": {
                "tags": [
                    "Autenticación"
                ],
                "description": "HU-03: Revoca el token actual.",
                "operationId": "authLogout",
                "responses": {
                    "200": {
                        "description": "Sesión cerrada"
                    },
                    "401": {
                        "description": "No autenticado"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/user/profile": {
            "get": {
                "tags": [
                    "Usuario"
                ],
                "description": "HU-04: Datos del usuario autenticado (sin contraseña), rol, estado y wallet.",
                "operationId": "userProfile",
                "responses": {
                    "200": {
                        "description": "Perfil"
                    },
                    "401": {
                        "description": "No autenticado"
                    },
                    "403": {
                        "description": "Cuenta no disponible"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/events/{sportEvent}/odds": {
            "get": {
                "tags": [
                    "Odds"
                ],
                "summary": "Listar cuotas disponibles de un evento",
                "description": "HU-16: Devuelve cuotas activas agrupadas por mercado y bookmaker.",
                "operationId": "9b267f38643693f2022f2f330b8d1e73",
                "parameters": [
                    {
                        "name": "sportEvent",
                        "in": "path",
                        "description": "ID interno del evento deportivo",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Cuotas disponibles obtenidas correctamente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Cuotas disponibles obtenidas correctamente."
                                        },
                                        "data": {
                                            "properties": {
                                                "event_id": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "external_event_id": {
                                                    "type": "string",
                                                    "example": "abc123"
                                                },
                                                "sport_key": {
                                                    "type": "string",
                                                    "example": "soccer_epl"
                                                },
                                                "markets": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "object"
                                                    }
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Evento no encontrado"
                    }
                }
            }
        },
        "/admin/odds/sync": {
            "post": {
                "tags": [
                    "Admin Odds"
                ],
                "summary": "Sincronizar cuotas desde The Odds API",
                "description": "HU-13, HU-14 y HU-15: Consulta cuotas por deporte, región y mercado; guarda snapshots y detecta cambios por hash.",
                "operationId": "0e6454998b59259290165bb219baf64e",
                "parameters": [
                    {
                        "name": "sport_key",
                        "in": "query",
                        "description": "Filtrar eventos por deporte",
                        "required": false,
                        "schema": {
                            "type": "string"
                        },
                        "example": "soccer_epl"
                    },
                    {
                        "name": "event_id",
                        "in": "query",
                        "description": "ID interno del evento específico",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    },
                    {
                        "name": "regions",
                        "in": "query",
                        "description": "Regiones de bookmakers",
                        "required": false,
                        "schema": {
                            "type": "string"
                        },
                        "example": "eu"
                    },
                    {
                        "name": "markets",
                        "in": "query",
                        "description": "Mercados de apuesta",
                        "required": false,
                        "schema": {
                            "type": "string"
                        },
                        "example": "h2h"
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "Cantidad máxima de eventos a procesar",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 10
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Cuotas sincronizadas correctamente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Cuotas sincronizadas correctamente."
                                        },
                                        "data": {
                                            "properties": {
                                                "events_processed": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "created": {
                                                    "type": "integer",
                                                    "example": 6
                                                },
                                                "unchanged": {
                                                    "type": "integer",
                                                    "example": 2
                                                },
                                                "deactivated": {
                                                    "type": "integer",
                                                    "example": 1
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "No autenticado"
                    },
                    "403": {
                        "description": "No autorizado"
                    },
                    "500": {
                        "description": "Error al sincronizar cuotas"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/sports/active": {
            "get": {
                "tags": [
                    "Sports"
                ],
                "summary": "Listar deportes activos",
                "description": "HU-07: Devuelve los deportes activos disponibles para el usuario final.",
                "operationId": "5369b278c4142ada5d56815afe4d99fe",
                "responses": {
                    "200": {
                        "description": "Deportes activos obtenidos correctamente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Deportes activos obtenidos correctamente."
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "id": {
                                                        "type": "integer",
                                                        "example": 1
                                                    },
                                                    "sport_key": {
                                                        "type": "string",
                                                        "example": "soccer_epl"
                                                    },
                                                    "group": {
                                                        "type": "string",
                                                        "example": "Soccer"
                                                    },
                                                    "title": {
                                                        "type": "string",
                                                        "example": "EPL"
                                                    },
                                                    "description": {
                                                        "type": "string",
                                                        "example": "English Premier League"
                                                    },
                                                    "active": {
                                                        "type": "boolean",
                                                        "example": true
                                                    },
                                                    "has_outrights": {
                                                        "type": "boolean",
                                                        "example": false
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/admin/sports": {
            "get": {
                "tags": [
                    "Admin Sports"
                ],
                "summary": "Listar deportes para administración",
                "description": "Devuelve deportes paginados para administración, con filtros opcionales.",
                "operationId": "d90dbc5eeea7b8273c215ae47331229a",
                "parameters": [
                    {
                        "name": "search",
                        "in": "query",
                        "description": "Buscar por nombre, sport_key o grupo",
                        "required": false,
                        "schema": {
                            "type": "string"
                        },
                        "example": "soccer"
                    },
                    {
                        "name": "active",
                        "in": "query",
                        "description": "Filtrar por estado activo/inactivo",
                        "required": false,
                        "schema": {
                            "type": "boolean"
                        },
                        "example": true
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Cantidad de registros por página",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 15
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Deportes obtenidos correctamente"
                    },
                    "401": {
                        "description": "No autenticado"
                    },
                    "403": {
                        "description": "No autorizado"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/admin/sports/sync": {
            "post": {
                "tags": [
                    "Admin Sports"
                ],
                "summary": "Sincronizar deportes desde The Odds API",
                "description": "HU-06: Consulta The Odds API y guarda o actualiza deportes sin duplicarlos.",
                "operationId": "1e1b4d998b3635bc00258462a32f54b3",
                "responses": {
                    "200": {
                        "description": "Deportes sincronizados correctamente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Deportes sincronizados correctamente."
                                        },
                                        "data": {
                                            "properties": {
                                                "total_received": {
                                                    "type": "integer",
                                                    "example": 70
                                                },
                                                "created": {
                                                    "type": "integer",
                                                    "example": 10
                                                },
                                                "updated": {
                                                    "type": "integer",
                                                    "example": 60
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "No autenticado"
                    },
                    "403": {
                        "description": "No autorizado"
                    },
                    "500": {
                        "description": "Error al sincronizar deportes"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/admin/sports/{sport}/status": {
            "patch": {
                "tags": [
                    "Admin Sports"
                ],
                "summary": "Activar o desactivar deporte",
                "description": "HU-08: Permite a un administrador activar o desactivar un deporte.",
                "operationId": "53252d5613f019a33414181316dae75b",
                "parameters": [
                    {
                        "name": "sport",
                        "in": "path",
                        "description": "ID del deporte",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "active"
                                ],
                                "properties": {
                                    "active": {
                                        "type": "boolean",
                                        "example": false
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Estado actualizado correctamente"
                    },
                    "401": {
                        "description": "No autenticado"
                    },
                    "403": {
                        "description": "No autorizado"
                    },
                    "422": {
                        "description": "Error de validación"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/events": {
            "get": {
                "tags": [
                    "Events"
                ],
                "summary": "Listar eventos deportivos disponibles",
                "description": "HU-10: Lista eventos activos y disponibles para apostar. Permite filtrar por sport_key.",
                "operationId": "08bb4f6a89011fba0aa159a9c841c2b5",
                "parameters": [
                    {
                        "name": "sport_key",
                        "in": "query",
                        "description": "Clave del deporte",
                        "required": false,
                        "schema": {
                            "type": "string"
                        },
                        "example": "soccer_epl"
                    },
                    {
                        "name": "status",
                        "in": "query",
                        "description": "Estado del evento",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "scheduled",
                                "live"
                            ]
                        },
                        "example": "scheduled"
                    },
                    {
                        "name": "date_from",
                        "in": "query",
                        "description": "Fecha inicial",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date"
                        },
                        "example": "2026-05-01"
                    },
                    {
                        "name": "date_to",
                        "in": "query",
                        "description": "Fecha final",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date"
                        },
                        "example": "2026-05-30"
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Cantidad de registros por página",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 15
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Eventos deportivos obtenidos correctamente"
                    },
                    "422": {
                        "description": "Error de validación"
                    }
                }
            }
        },
